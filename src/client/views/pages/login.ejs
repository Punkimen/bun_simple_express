<div class="login-page">
  <div class="login-card">
    <div class="login-logo">💰</div>
    <h1 class="login-title">Мой бюджет</h1>
    <p class="login-sub">Войдите, чтобы продолжить</p>
    <form
      class="login-form"
      x-data="{ hasError: false }"
      hx-post="/api/login"
      x-on:htmx:before-request="hasError = false"
      x-on:htmx:response-error="hasError = true"
    >
      <div class="form-group">
        <label for="login-input">Логин</label>
        <input
          id="login-input"
          name="login"
          value=""
          placeholder="Логин"
          autocomplete="username"
          :class="{ error: hasError }"
        />
      </div>
      <div class="form-group">
        <label for="pass-input">Пароль</label>
        <input
          id="pass-input"
          name="password"
          type="password"
          value=""
          placeholder="Пароль"
          autocomplete="current-password"
          :class="{ error: hasError }"
        />
      </div>
      <p x-show="hasError" class="login-error">Неверный логин или пароль</p>
      <button type="submit" class="login-btn">Войти</button>
    </form>
  </div>
</div>
