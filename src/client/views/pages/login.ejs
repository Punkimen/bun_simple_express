<div class="login-page">
  <div class="login-card" x-data="{
    mode: 'login',
    registerError: '',
    regShowPass: false,
    regShowConfirm: false,
    regPassword: '',
    regConfirm: '',
    get passwordMismatch() { return this.regConfirm.length > 0 && this.regPassword !== this.regConfirm }
  }">
    <div class="login-logo">
    <img src="/public/images/logo_budget.svg" />
    </div>

    <!-- Login form -->
    <div x-show="mode === 'login'">
      <p class="login-sub">Войдите, чтобы продолжить</p>
      <form class="login-form" x-data="{ hasError: false }" hx-post="/api/login" hx-ext="json-enc"
        x-on:htmx:before-request="hasError = false" x-on:htmx:response-error="hasError = true">
        <div class="form-group">
          <label for="login-input">Логин</label>
          <input id="login-input" name="login" value="" placeholder="Логин" autocomplete="username"
            :class="{ error: hasError }" />
        </div>
        <div class="form-group" x-data="{showPass: false}">
          <label for="pass-input">Пароль</label>
          <div class="pass-wrapper">
            <input id="pass-input" name="password" :type="showPass ? 'text' : 'password'" value="" placeholder="Пароль"
              autocomplete="current-password" :class="{ error: hasError }" />
            <button type="button" class="pass-toggle" @click="showPass = !showPass"
              :aria-label="showPass ? 'Скрыть пароль' : 'Показать пароль'">
              <svg x-show="!showPass" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
              <svg x-show="showPass" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path
                  d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" />
                <line x1="1" y1="1" x2="23" y2="23" />
              </svg>
            </button>
          </div>
        </div>
        <p x-show="hasError" class="login-error">Неверный логин или пароль</p>
        <button type="submit" class="login-btn">Войти</button>
      </form>
      <div style="text-align:right;margin-top:0.5rem">
        <a href="/forgot-password" class="login-forgot">Забыли пароль?</a>
      </div>
      <div class="login-divider"><span>или</span></div>
      <a href="/api/getGoogleOauth" class="login-btn-google">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48">
          <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
          <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
          <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
          <path fill="none" d="M0 0h48v48H0z"/>
        </svg>
        Войти через Google
      </a>
      <div class="login-divider"><span>или</span></div>
      <button type="button" class="login-btn-secondary" @click="mode = 'register'">Создать аккаунт</button>
    </div>

    <!-- Register form -->
    <div x-show="mode === 'register'">
      <p class="login-sub">Создайте новый аккаунт</p>
      <form class="login-form" hx-post="/api/register" hx-ext="json-enc"
        x-on:htmx:before-request="registerError = ''"
        x-on:htmx:response-error="registerError = 'Ошибка регистрации. Возможно, этот email уже используется.'">
        <div class="form-group">
          <label for="reg-name">Имя</label>
          <input id="reg-name" name="name" placeholder="Ваше имя" autocomplete="name" required />
        </div>
        <div class="form-group">
          <label for="reg-login">Логин (email)</label>
          <input id="reg-login" name="login" type="email" placeholder="Email" autocomplete="username" required />
        </div>
        <div class="form-group">
          <label for="reg-pass">Пароль</label>
          <div class="pass-wrapper">
            <input id="reg-pass" name="password" :type="regShowPass ? 'text' : 'password'"
              x-model="regPassword" placeholder="Пароль" autocomplete="new-password" required />
            <button type="button" class="pass-toggle" @click="regShowPass = !regShowPass"
              :aria-label="regShowPass ? 'Скрыть пароль' : 'Показать пароль'">
              <svg x-show="!regShowPass" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
              <svg x-show="regShowPass" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path
                  d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" />
                <line x1="1" y1="1" x2="23" y2="23" />
              </svg>
            </button>
          </div>
        </div>
        <div class="form-group">
          <label for="reg-confirm">Подтверждение пароля</label>
          <div class="pass-wrapper">
            <input id="reg-confirm" name="confirmPassword" :type="regShowConfirm ? 'text' : 'password'"
              x-model="regConfirm" placeholder="Повторите пароль" autocomplete="new-password"
              :class="{ error: passwordMismatch }" required />
            <button type="button" class="pass-toggle" @click="regShowConfirm = !regShowConfirm"
              :aria-label="regShowConfirm ? 'Скрыть пароль' : 'Показать пароль'">
              <svg x-show="!regShowConfirm" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
              <svg x-show="regShowConfirm" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path
                  d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" />
                <line x1="1" y1="1" x2="23" y2="23" />
              </svg>
            </button>
          </div>
          <p x-show="passwordMismatch" class="login-error" style="margin-top:0.5rem;text-align:left">Пароли не совпадают</p>
        </div>
        <p x-show="registerError" x-text="registerError" class="login-error"></p>
        <button type="submit" class="login-btn" :disabled="passwordMismatch">Создать аккаунт</button>
      </form>
      <div class="login-divider"><span>или</span></div>
      <button type="button" class="login-btn-secondary" @click="mode = 'login'; registerError = ''">Уже есть аккаунт? Войти</button>
    </div>
  </div>
</div>
