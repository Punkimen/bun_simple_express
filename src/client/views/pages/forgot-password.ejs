<div class="login-page">
  <div class="login-card" x-data="{
    sent: false,
    error: '',
  }">
    <div class="login-logo">
      <img src="/public/images/logo_budget.svg" />
    </div>

    <div x-show="!sent">
      <p class="login-sub">Введите email для сброса пароля</p>
      <form class="login-form" hx-post="/api/password-reset" hx-ext="json-enc"
        x-on:htmx:before-request="error = ''"
        x-on:htmx:after-request="if(event.detail.successful) sent = true"
        x-on:htmx:response-error="error = 'Пользователь с таким email не найден'">
        <div class="form-group">
          <label for="email-input">Email</label>
          <input id="email-input" name="email" type="email" placeholder="Email" autocomplete="email" required
            :class="{ error: error }" />
        </div>
        <p x-show="error" x-text="error" class="login-error"></p>
        <button type="submit" class="login-btn">Отправить ссылку</button>
      </form>
    </div>

    <div x-show="sent">
      <p class="login-sub">Письмо отправлено</p>
      <p style="text-align:center;color:var(--text-secondary);margin-bottom:1.5rem">
        Проверьте почту и перейдите по ссылке для сброса пароля. Ссылка действует 15 минут.
      </p>
    </div>

    <div class="login-divider"><span>или</span></div>
    <a href="/login" class="login-btn-secondary" style="display:block;text-align:center;text-decoration:none">Вернуться ко входу</a>
  </div>
</div>
