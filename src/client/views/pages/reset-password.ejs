<div class="login-page">
  <div class="login-card" x-data="{
    newPass: '',
    confirmPass: '',
    showNew: false,
    showConfirm: false,
    error: '',
    get mismatch() { return this.confirmPass.length > 0 && this.newPass !== this.confirmPass }
  }">
    <div class="login-logo">
      <img src="/public/images/logo_budget.svg" />
    </div>

    <% if (!token) { %>
      <p class="login-sub" style="color:#f87171;margin-bottom:1.5rem">Ссылка недействительна или устарела</p>
    <% } else { %>
      <p class="login-sub">Придумайте новый пароль</p>
      <form class="login-form" hx-post="/api/reset-password" hx-ext="json-enc"
        x-on:htmx:before-request="error = ''"
        x-on:htmx:response-error="error = (() => { try { return JSON.parse(event.detail.xhr.responseText).error } catch { return 'Ошибка. Возможно, ссылка уже использована или истекла' } })()">
        <input type="hidden" name="token" value="<%= token %>" />
        <div class="form-group">
          <label for="new-pass">Новый пароль</label>
          <div class="pass-wrapper">
            <input id="new-pass" name="newPassword" :type="showNew ? 'text' : 'password'"
              x-model="newPass" placeholder="Новый пароль" autocomplete="new-password" required />
            <button type="button" class="pass-toggle" @click="showNew = !showNew"
              :aria-label="showNew ? 'Скрыть пароль' : 'Показать пароль'">
              <svg x-show="!showNew" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" />
              </svg>
              <svg x-show="showNew" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" />
                <line x1="1" y1="1" x2="23" y2="23" />
              </svg>
            </button>
          </div>
        </div>
        <div class="form-group">
          <label for="confirm-pass">Подтверждение пароля</label>
          <div class="pass-wrapper">
            <input id="confirm-pass" name="confirmPassword" :type="showConfirm ? 'text' : 'password'"
              x-model="confirmPass" placeholder="Повторите пароль" autocomplete="new-password"
              :class="{ error: mismatch }" required />
            <button type="button" class="pass-toggle" @click="showConfirm = !showConfirm"
              :aria-label="showConfirm ? 'Скрыть пароль' : 'Показать пароль'">
              <svg x-show="!showConfirm" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" />
              </svg>
              <svg x-show="showConfirm" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" />
                <line x1="1" y1="1" x2="23" y2="23" />
              </svg>
            </button>
          </div>
          <p x-show="mismatch" class="login-error" style="margin-top:0.5rem;text-align:left">Пароли не совпадают</p>
        </div>
        <p x-show="error" x-text="error" class="login-error"></p>
        <button type="submit" class="login-btn" :disabled="mismatch">Сохранить пароль</button>
      </form>
    <% } %>
    <div class="login-divider"><span>или</span></div>
    <a href="/login" class="login-btn-secondary" style="display:block;text-align:center;text-decoration:none">Вернуться ко входу</a>
  </div>
</div>
